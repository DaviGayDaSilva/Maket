#!/data/data/com.termux/files/usr/bin/bash
#
# maket - Run Linux ISO or rootfs without root on Termux
# Alternative to proot for Termux
#

VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="/data/data/com.termux/files/usr/lib/maket"
CONFIG_DIR="${HOME}/.config/maket"
ISO_MOUNT_DIR="${HOME}/.maket/isomnt"
ROOTFS_RUN_DIR="${HOME}/.maket/rootfs_run"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Source library functions
source "${LIB_DIR}/maket-lib.sh"

# Show usage
usage() {
    cat <<EOF
maket v${VERSION} - Run Linux ISO or rootfs without root on Termux

Usage: maket <command> [options]

Commands:
    run <target>           Run ISO file or rootfs directory
    run --iso <iso>       Run Linux ISO (alias for 'run <iso>')
    run --rootfs <dir>   Run rootfs directory (alternative to proot)
    list                  List available ISOs and rootfs
    mount <iso>           Mount ISO temporarily
    umount <iso>         Unmount ISO
    status                Show current status
    install-deps          Install required dependencies
    cleanup               Clean up temporary files

Options:
    -h, --help            Show this help
    -v, --version         Show version
    -d, --display :1      VNC display number (default: :1)
    -m, --memory 512M     Memory for QEMU (default: 512M)
    -c, --cpu 2           CPU cores (default: 2)
    --no-vnc              Run without VNC (console only)
    --vnc-passwd <pass>   VNC password

Examples:
    maket run archlinux-2024.01.01-x86_64.iso
    maket run --iso debian-12.0.0-amd64.iso
    maket run --rootfs /sdcard/Download/ubuntu
    maket run --rootfs /sdcard/Download/ubuntu --display :2

EOF
}

# Parse command line arguments
parse_args() {
    COMMAND=""
    TARGET=""
    ISO_FILE=""
    ROOTFS_DIR=""
    DISPLAY=":1"
    MEMORY="512M"
    CPU="2"
    NO_VNC=false
    VNC_PASSWD=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            run)
                COMMAND="run"
                shift
                if [[ "$1" == "--iso" ]]; then
                    shift
                    ISO_FILE="$1"
                elif [[ "$1" == "--rootfs" ]]; then
                    shift
                    ROOTFS_DIR="$1"
                elif [[ -n "$1" && ! "$1" =~ ^- ]]; then
                    TARGET="$1"
                fi
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            -v|--version)
                echo "maket v${VERSION}"
                exit 0
                ;;
            -d|--display)
                DISPLAY="$2"
                shift 2
                ;;
            -m|--memory)
                MEMORY="$2"
                shift 2
                ;;
            -c|--cpu)
                CPU="$2"
                shift 2
                ;;
            --no-vnc)
                NO_VNC=true
                shift
                ;;
            --vnc-passwd)
                VNC_PASSWD="$2"
                shift 2
                ;;
            list|install-deps|cleanup|status|mount|umount)
                COMMAND="$1"
                shift
                ;;
            *)
                if [[ -n "$TARGET" ]]; then
                    TARGET="$TARGET $1"
                fi
                shift
                ;;
        esac
    done
    
    # Handle target as ISO or rootfs
    if [[ -n "$TARGET" ]]; then
        # First check if file exists as given
        if [[ -f "$TARGET" ]]; then
            if [[ "$TARGET" =~ \.iso$ ]]; then
                ISO_FILE="$TARGET"
            else
                ROOTFS_DIR="$TARGET"
            fi
        # Try to find ISO file
        elif [[ -n "$(find_iso "$TARGET" 2>/dev/null)" ]]; then
            ISO_FILE="$(find_iso "$TARGET")"
        else
            # Assume it's a rootfs directory
            ROOTFS_DIR="$TARGET"
        fi
    fi
}

# Main execution
main() {
    parse_args "$@"
    
    # Create required directories
    mkdir -p "${ISO_MOUNT_DIR}" "${ROOTFS_RUN_DIR}" "${CONFIG_DIR}"
    
    case "${COMMAND}" in
        run)
            if [[ -n "${ISO_FILE}" ]]; then
                run_iso "${ISO_FILE}" "${DISPLAY}" "${MEMORY}" "${CPU}" "${NO_VNC}" "${VNC_PASSWD}"
            elif [[ -n "${ROOTFS_DIR}" ]]; then
                run_rootfs "${ROOTFS_DIR}" "${DISPLAY}" "${MEMORY}" "${CPU}" "${NO_VNC}" "${VNC_PASSWD}"
            else
                echo -e "${RED}Error: No ISO or rootfs specified${NC}"
                usage
                exit 1
            fi
            ;;
        list)
            list_available
            ;;
        mount)
            mount_iso "${ISO_FILE}"
            ;;
        umount)
            umount_iso "${ISO_FILE}"
            ;;
        install-deps)
            install_dependencies
            ;;
        cleanup)
            cleanup_temp
            ;;
        status)
            show_status
            ;;
        "")
            usage
            exit 1
            ;;
        *)
            echo -e "${RED}Unknown command: ${COMMAND}${NC}"
            usage
            exit 1
            ;;
    esac
}

main "$@"